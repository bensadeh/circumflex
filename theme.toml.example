# circumflex theme configuration
#
# Copy this file to your config directory as theme.toml, or run
# `clx default-theme` to write it there for you.
# Only include the values you want to override — unspecified values
# keep their defaults.
#
# Color values can be:
#   - Named: "red", "blue", "green", "yellow", "magenta", "cyan", "white", "black"
#   - Bright: "bright_red", "bright_blue", "bright_green", etc.
#   - ANSI 256: "219", "33", "196"
#   - Hex: "#ff5500", "#1a1a2e"

[app]
  primary = "magenta"
  secondary = "yellow"
  tertiary = "blue"

[headline]
  ask_hn = "blue"
  show_hn = "red"
  tell_hn = "magenta"
  thank_hn = "cyan"
  launch_hn = "green"
  yc_label = "yellow"
  year = "magenta"
  audio = "cyan"
  video = "cyan"
  pdf = "cyan"

[comment]
  url = "blue"
  mention = "yellow"
  mod = "green"
  variable = "cyan"
  backtick = "magenta"
  op = "red"
  gp = "magenta"
  new_indicator = "cyan"

[meta]
  author = "red"
  score = "yellow"
  comments = "magenta"
  new_comments = "cyan"
  url = "blue"

[reader]
  h1 = "blue"
  h2 = "red"
  h3 = "magenta"
  h4 = "yellow"
  h5 = "green"
  h6 = "white"
  image = "red"
  link = "blue"

[code]
  keyword = "magenta"
  string = "green"
  literal = "cyan"
  type = "yellow"
  function = "blue"
  escape = "red"

[header]
  c = "magenta"
  l = "yellow"
  x = "blue"

[indent]
  cycle = ["red", "yellow", "green", "cyan", "blue", "magenta", "bright_red", "bright_yellow", "bright_green", "bright_cyan", "bright_blue", "bright_magenta"]

[search]
  match = "yellow"
  current = "yellow"
